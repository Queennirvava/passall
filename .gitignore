# =========================================================
# .gitignore 规则说明
# 每一行是一个匹配规则，匹配到的文件/目录不会被 git 追踪
# 以 # 开头的是注释
# 以 / 结尾表示只匹配目录
# 以 * 开头表示通配符，匹配任意字符
# 以 ! 开头表示「例外」，强制追踪某个文件
# =========================================================


# ---------------------------------------------------------
# Go 编译产物
# go build 会在项目目录生成与包名同名的二进制文件
# 二进制是由源码编译出来的，不需要上传，任何人 clone 后
# 执行 go build 就能得到，上传反而会让仓库变得很大
# ---------------------------------------------------------
passall


# ---------------------------------------------------------
# Go 测试缓存与覆盖率文件
# go test 运行后可能生成这些文件
# *.out  是 go test -cpuprofile 等命令生成的性能分析文件
# *.test 是 go test -c 生成的测试二进制文件
# ---------------------------------------------------------
*.out
*.test


# ---------------------------------------------------------
# 环境变量文件
# 开发时常用 .env 存放本地的密钥、数据库密码等敏感信息
# 这类文件绝对不能上传到 GitHub，否则密钥会泄露
# .env.example 可以上传（作为模板，里面不放真实值）
# ---------------------------------------------------------
.env
.env.local


# ---------------------------------------------------------
# macOS 系统文件
# Finder 会在每个目录自动创建 .DS_Store 文件来存储视图设置
# 这是系统文件，和项目本身无关，不需要上传
# ---------------------------------------------------------
.DS_Store


# ---------------------------------------------------------
# Claude Code 本地配置
# .claude/ 存放 Claude AI 的项目记忆和本地配置，不需要上传
# ---------------------------------------------------------
.claude/


# ---------------------------------------------------------
# IDE / 编辑器配置
# 这些是你本地编辑器的个人配置，别人用不同编辑器不需要
# .idea/     JetBrains（GoLand）生成的项目配置目录
# .vscode/   VS Code 生成的工作区配置目录
# 注意：如果团队约定统一用某编辑器，也可以选择提交 .vscode/
# ---------------------------------------------------------
.idea/
.vscode/


# ---------------------------------------------------------
# 以下是「例外」示范，暂时用不到，了解语法即可
# 假设你想忽略所有 *.log 文件，但保留 important.log：
# *.log
# !important.log
# ---------------------------------------------------------
